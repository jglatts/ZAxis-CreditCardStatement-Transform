<Window x:Class="ZAxis_CreditCardStatement_Transform.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Credit Card Statement Transform"
        Height="450"
        Width="800"
        MinHeight="400"
        MinWidth="650"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Z-Axis Connector Company"
                       FontSize="24"
                       FontWeight="Bold"/>

            <TextBlock Text="Credit Card Statement Sage Transform"
                       Margin="0,5,0,0"
                       FontSize="16"
                       FontStyle="Italic"
                       Foreground="DimGray"/>
        </StackPanel>

        <!-- File selection -->
        <GroupBox Grid.Row="2"
                  Header="File Information"
                  Padding="15">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Column="0"
                       Content="CSV File:"
                       VerticalAlignment="Center"
                       Padding="0"
                       Margin="0,0,10,0"/>

                <TextBox x:Name="txtBoxCSVFileName"
                         Grid.Column="1"
                         Height="30"
                         Padding="7,4"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"/>

                <Button x:Name="btnBrowseFiles"
                        Grid.Column="2"
                        Content="Browse..."
                        Width="110"
                        Height="30"
                        Margin="10,0,0,0"
                        Click="btnBrowseFiles_Click"/>
            </Grid>
        </GroupBox>

        <!-- Action button -->
        <Button x:Name="btnLoadAndTransform"
                Grid.Row="4"
                Content="Load &amp; Transform"
                Width="200"
                Height="40"
                HorizontalAlignment="Left"
                FontSize="14"
                FontWeight="SemiBold"
                Click="btnLoadAndTransform_Click"/>

    </Grid>
</Window>