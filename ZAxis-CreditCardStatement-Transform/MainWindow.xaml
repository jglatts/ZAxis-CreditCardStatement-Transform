<Window x:Class="ZAxis_CreditCardStatement_Transform.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Credit Card Statement Transform"
        Height="500"
        Width="820"
        MinHeight="460"
        MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Window.Resources>

        <!-- Primary action button -->
        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="44"/>

            <Setter Property="Padding"
                    Value="20,8"/>

            <Setter Property="FontSize"
                    Value="14"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#1F5A94"/>

            <Setter Property="BorderBrush"
                    Value="#1F5A94"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#174873"/>

                    <Setter Property="BorderBrush"
                            Value="#174873"/>
                </Trigger>

                <Trigger Property="IsPressed"
                         Value="True">

                    <Setter Property="Background"
                            Value="#103551"/>
                </Trigger>

                <Trigger Property="IsEnabled"
                         Value="False">

                    <Setter Property="Opacity"
                            Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary action button -->
        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="36"/>

            <Setter Property="Padding"
                    Value="16,6"/>

            <Setter Property="FontSize"
                    Value="13"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Foreground"
                    Value="#263238"/>

            <Setter Property="Background"
                    Value="White"/>

            <Setter Property="BorderBrush"
                    Value="#C8CDD2"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#EEF2F5"/>

                    <Setter Property="BorderBrush"
                            Value="#AAB1B7"/>
                </Trigger>

                <Trigger Property="IsPressed"
                         Value="True">

                    <Setter Property="Background"
                            Value="#E1E6EA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground"
                    Value="#263238"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Background"
                    Value="White"/>

            <Setter Property="BorderBrush"
                    Value="#D7DCE1"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Padding"
                    Value="18"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"
                    Value="#FAFBFC"/>

            <Setter Property="BorderBrush"
                    Value="#C8CDD2"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Padding"
                    Value="9,5"/>

            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="22"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <TextBlock Text="Credit Card Statement Transform"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="#20272D"/>

                <TextBlock Text="Convert credit card CSV statements into the Sage import format."
                           Margin="0,6,0,0"
                           FontSize="14"
                           Foreground="#68737D"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="12,7"
                    Background="#E7EEF6"
                    CornerRadius="5"
                    VerticalAlignment="Top">

                <TextBlock Text="Z-Axis Connector Company"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1F5A94"/>
            </Border>
        </Grid>

        <!-- File card -->
        <GroupBox Grid.Row="2"
                  Header="Statement File">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.ColumnSpan="2"
                           Text="Select the original credit card statement CSV file."
                           FontWeight="Normal"
                           Foreground="#68737D"/>

                <TextBox x:Name="txtBoxCSVFileName"
                         Grid.Row="2"
                         Grid.Column="0"
                         Height="34"
                         IsReadOnly="True"/>

                <Button x:Name="btnBrowseFiles"
                        Grid.Row="2"
                        Grid.Column="1"
                        Content="Browse..."
                        Width="110"
                        Margin="10,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="btnBrowseFiles_Click"/>
            </Grid>
        </GroupBox>

        <!-- Main action -->
        <Button x:Name="btnLoadAndTransform"
                Grid.Row="4"
                Content="Load and Transform Statement"
                HorizontalAlignment="Stretch"
                Style="{StaticResource PrimaryButtonStyle}"
                Click="btnLoadAndTransform_Click"/>

        <!-- Rule management -->
        <Border Grid.Row="6"
                Padding="18"
                Background="White"
                BorderBrush="#D7DCE1"
                BorderThickness="1"
                CornerRadius="5">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">

                    <TextBlock Text="GL Mapping Rules"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#263238"/>

                    <TextBlock Text="View, edit, add, or remove merchant keyword mappings."
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#68737D"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="btnViewRules"
                            Content="Manage Rules"
                            Width="125"
                            Margin="0,0,8,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="btnViewRules_Click"/>

                </StackPanel>
            </Grid>
        </Border>

        <!-- Status/footer -->

    </Grid>
</Window>