<Window x:Class="ZAxis_CreditCardStatement_Transform.AddRuleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Mapping Rule"
        Width="440"
        Height="255"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Add GL Mapping Rule"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,15"/>

        <Grid Grid.Row="1"
              Margin="0,0,0,12">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Description keyword:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="txtDescriptionKeyword"
                     Grid.Column="1"
                     Height="28"
                     VerticalContentAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="GL account number:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="txtAccountNumber"
                     Grid.Column="1"
                     Height="28"
                     VerticalContentAlignment="Center"/>
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="140,8,0,0"
                   Foreground="DimGray"
                   Text="Example: AMAZON, 60180"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Add Rule"
                    Width="90"
                    Height="30"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="btnAdd_Click"/>

            <Button Content="Cancel"
                    Width="90"
                    Height="30"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>