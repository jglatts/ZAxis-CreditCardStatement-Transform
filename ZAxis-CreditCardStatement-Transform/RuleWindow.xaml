<Window x:Class="ZAxis_CreditCardStatement_Transform.RulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GL Mapping Rules"
        Width="950"
        Height="600"
        MinWidth="700"
        MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,12">

            <TextBlock Text="GL Mapping Rules"
                       FontSize="22"
                       FontWeight="SemiBold"/>

            <TextBlock Text="Transactions are matched against these rules from top to bottom. Double-click a cell to edit it."
                       Margin="0,4,0,0"
                       Foreground="DimGray"/>
        </StackPanel>

        <DataGrid x:Name="rulesDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#FFF4F4F4">

            <DataGrid.Columns>
                <DataGridTextColumn Header="#"
                                    Binding="{Binding RuleNumber}"
                                    IsReadOnly="True"
                                    Width="50"/>

                <DataGridTextColumn Header="Keyword"
                                    Binding="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"
                                    MinWidth="250"/>

                <DataGridTextColumn Header="GL Account Number"
                                    Binding="{Binding AccountNumber, UpdateSourceTrigger=PropertyChanged}"
                                    Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2"
              Margin="0,12,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal">

                <Button Content="Add"
                        Width="80"
                        Height="30"
                        Margin="0,0,8,0"
                        Click="btnAdd_Click"/>

                <Button Content="Delete"
                        Width="80"
                        Height="30"
                        Click="btnDelete_Click"/>
            </StackPanel>

            <TextBlock x:Name="ruleCountTextBlock"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Margin="15,0,15,0"
                       Foreground="DimGray"/>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal">

                <Button Content="Save"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="btnSave_Click"/>

                <Button Content="Cancel"
                        Width="90"
                        Height="30"
                        IsCancel="True"
                        Click="btnClose_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>