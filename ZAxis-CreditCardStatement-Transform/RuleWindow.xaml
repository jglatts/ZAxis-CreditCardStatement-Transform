<Window x:Class="ZAxis_CreditCardStatement_Transform.RulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GL Mapping Rules"
        Width="950"
        Height="600"
        MinWidth="700"
        MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,12">

            <TextBlock Text="GL Mapping Rules"
                       FontSize="22"
                       FontWeight="SemiBold"/>

            <TextBlock Text="Transactions are matched against these rules from top to bottom."
                       Margin="0,4,0,0"
                       Foreground="DimGray"/>
        </StackPanel>

        <DataGrid x:Name="rulesDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="True"
                  CanUserSortColumns="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#FFF4F4F4">

            <DataGrid.Columns>
                <DataGridTextColumn Header="#"
                                    Binding="{Binding RuleNumber}"
                                    Width="50"/>

                <DataGridTextColumn Header="Card"
                                    Binding="{Binding CardDisplay}"
                                    Width="130"/>

                <DataGridTextColumn Header="Description"
                                    Binding="{Binding DescriptionDisplay}"
                                    Width="*"
                                    MinWidth="180"/>

                <DataGridTextColumn Header="Category"
                                    Binding="{Binding CategoryDisplay}"
                                    Width="*"
                                    MinWidth="160"/>

                <DataGridTextColumn Header="GL Account"
                                    Binding="{Binding AccountNumber}"
                                    Width="110"/>

                <DataGridTextColumn Header="Account Description"
                                    Binding="{Binding AccountDescription}"
                                    Width="*"
                                    MinWidth="220"/>
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="2"
                   Margin="0,12,0,0">

            <TextBlock x:Name="ruleCountTextBlock"
                       VerticalAlignment="Center"
                       Foreground="DimGray"/>

            <Button Content="Close"
                    Width="90"
                    Height="30"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    IsCancel="True"
                    Click="btnClose_Click"/>
        </DockPanel>
    </Grid>
</Window>